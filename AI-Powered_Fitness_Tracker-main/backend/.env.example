# ─────────────────────────────────────────────────────────────
#  BFit Backend — Environment Variables
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# MongoDB  (local example shown; replace with Atlas URI in production)
MONGODB_URI=mongodb://localhost:27017/bfit

# Google Gemini API Key  (same key used by the Angular frontend)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# CORS — comma-separated list of allowed origins
# e.g. http://localhost:4200 for Angular dev server
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
